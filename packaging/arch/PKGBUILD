# Maintainer: Harsh Sahu <harsh@itssingularity.com> (Singularity Works - itssingularity.com)
pkgname=verso-bin
pkgver=0.3.88
pkgrel=1
pkgdesc="Personal knowledge base and folio, blog for public face & private brain, one app"
arch=('x86_64')
url="https://github.com/parazeeknova/verso"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3' 'libsoup3' 'libayatana-appindicator3' 'glib-networking')
optdepends=('gstreamer: audio/video support'
            'gst-plugins-base: audio/video support'
            'gst-plugins-good: audio/video support'
            'gst-plugins-bad: WebVTT subtitles and video support')
provides=('verso')
conflicts=('verso')
source=("https://github.com/parazeeknova/verso/releases/download/v${pkgver}/stable-linux-x64-Verso-Setup.tar.gz")
sha256sums=('0e59a6e827ce0645a283380d7b30688927c8ccf9c111b474525b8a8767f3d11f')

package() {
    # Install application files
    install -d "${pkgdir}/opt/verso"
    cp -r "${srcdir}/stable-linux-x64-Verso-Setup/"* "${pkgdir}/opt/verso/"
    
    # Create symlink in bin
    install -d "${pkgdir}/usr/bin"
    ln -s "/opt/verso/Verso" "${pkgdir}/usr/bin/verso"

    # Add .desktop and icon
    install -d "${pkgdir}/usr/share/applications"
    cat << EOF > "${pkgdir}/usr/share/applications/verso.desktop"
[Desktop Entry]
Name=Verso
Exec=verso
Icon=/opt/verso/resources/verso.png
Type=Application
Categories=Utility;
Terminal=false
Comment=Personal knowledge base and folio, blog for public face & private brain, one app
EOF
}
