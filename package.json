{
  "$schema": "https://raw.githubusercontent.com/SchemaStore/schemastore/refs/heads/master/src/schemas/json/package.json",
  "name": "verso",
  "version": "0.4.82",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check:ci": "ultracite check && lerna run check",
    "autobump": "go run scripts/autobump.go",
    "version:bump": "go run scripts/autobump.go bump",
    "version:get": "go run scripts/autobump.go get",
    "version:set": "go run scripts/autobump.go set",
    "version:sync": "go run scripts/autobump.go sync",
    "version:check": "go run scripts/autobump.go check",
    "test:version": "cd scripts && go test .",
    "build": "lerna run build",
    "check": "ultracite fix --unsafe && lerna run check",
    "check-types": "lerna run check-types",
    "dev": "lerna run dev",
    "infra:down": "docker compose -f docker/docker-compose.infrastructure.yml down",
    "infra:up": "docker compose -f docker/docker-compose.infrastructure.yml up -d",
    "db:migrate": "lerna run db:migrate",
    "db:reset": "lerna run db:reset",
    "test": "lerna run test",
    "al": "bun run check-types && bun run check && bun run test"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "lerna": "^9.0.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "ultracite": "7.6.1"
  },
  "overrides": {
    "prosemirror-model": "1.25.11",
    "prosemirror-view": "1.42.1"
  },
  "engines": {
    "node": ">=24"
  }
}
